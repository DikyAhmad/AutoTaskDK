{
  "name": "autotask-dk",
  "version": "1.0.2",
  "description": "Automated workflow and task runner for browsers",
  "main": "main.js",
  "build": {
    "appId": "com.autotaskdk.app",
    "productName": "AutoTask DK",
    "win": {
      "target": "nsis",
      "icon": "logo-autotaskdk.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "css:build": "tailwindcss -i renderer/input.css -o renderer/styles.css",
    "css:watch": "tailwindcss -i renderer/input.css -o renderer/styles.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.2.1"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
